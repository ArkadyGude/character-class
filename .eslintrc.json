{
  "env": {
    "browser": true,
    "es2021": true,
    "jest": true,
    "node": true
  },
  "extends": "airbnb-base",
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "rules": {
    "no-new": "off",
    "no-console": "off",
    "import/prefer-default-export": "off",
    "linebreak-style": "off",
    "import/extensions": "off"
  }
}
